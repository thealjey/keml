{
  "[html]": {
    "editor.defaultFormatter": "jkillian.custom-local-formatters"
  },
  "[markdown]": {
    "editor.defaultFormatter": "jkillian.custom-local-formatters",
    "files.trimTrailingWhitespace": false
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "black-formatter.args": ["--line-length=80"],
  "cSpell.words": [
    "depcruise",
    "frontends",
    "htmx",
    "keml",
    "Kuzmenko",
    "mkdocs",
    "Renderable"
  ],
  "customLocalFormatters.formatters": [
    {
      "command": "python -X utf8 -m examples.format_html",
      "languages": ["html"]
    },
    {
      "command": "python -X utf8 -m examples.format_html -l md",
      "languages": ["markdown"]
    }
  ],
  "editor.codeActionsOnSave": {
    "source.addMissingImports": "always",
    "source.fixAll": "always",
    "source.organizeImports": "always",
    "source.removeUnused": "always",
    "source.removeUnusedImports": "always",
    "source.sort.json": "always",
    "source.sortImports": "always",
    "source.unusedImports": "always"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.dragAndDrop": false,
  "editor.emptySelectionClipboard": false,
  "editor.formatOnSave": true,
  "editor.rulers": [80],
  "editor.stickyScroll.enabled": false,
  "editor.tabSize": 2,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "prettier.arrowParens": "avoid",
  "prettier.experimentalTernaries": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.typeCheckingMode": "strict",
  "terminal.integrated.stickyScroll.enabled": false,
  "workbench.tree.enableStickyScroll": false
}
