{
  "author": "Eugene Kuzmenko",
  "bugs": {
    "url": "https://github.com/thealjey/keml/issues"
  },
  "description": "Enhance HTML with custom attributes for clean, server-driven interactivity.",
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "^4.0.3",
    "dependency-cruiser": "^17.1.0",
    "esbuild": "^0.25.11",
    "happy-dom": "^20.0.8",
    "vitest": "^4.0.3"
  },
  "files": [
    "keml.js",
    "LICENSE",
    "README.md"
  ],
  "homepage": "https://thealjey.github.io/keml/",
  "keywords": [
    "html",
    "server-rendered",
    "declarative",
    "no javascript",
    "interactive html",
    "htmx alternative",
    "progressive enhancement",
    "keml"
  ],
  "license": "MIT",
  "main": "keml.js",
  "name": "keml",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thealjey/keml.git"
  },
  "scripts": {
    "build": "node esbuild.config.mts",
    "demo:realworld": "python -X utf8 -m examples.realworld.server",
    "demo:todo": "python -X utf8 -m examples.todo.server",
    "docs:deploy": "mkdocs gh-deploy --force",
    "docs:serve": "mkdocs serve",
    "pip:install": "pip install --upgrade markdown mkdocs mkdocs-material",
    "prebuild": "depcruise --config .dependency-cruiser.mjs 'src/*.mts'",
    "test": "vitest run"
  },
  "version": "3.2.10"
}
